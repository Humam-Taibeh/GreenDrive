rules_version = '2';
// GreenDrive — Hardened Security Rules
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own profile document and sub-collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Also protect any sub-collections (like saved locations or routes)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
