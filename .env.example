# Output by Antigravity IDE — GreenDrive env template (copy to .env.local)

# Google Maps JavaScript API (client key with HTTP referrer restrictions)
VITE_GOOGLE_MAPS_API_KEY=

# AI copilot — OpenRouter (recommended; avoids direct Gemini billing 403 on free tier)
VITE_OPENROUTER_API_KEY=
# e.g. google/gemini-2.0-flash-lite-preview-09-2025:free or mistralai/mistral-7b-instruct:free
VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-09-2025:free

# Legacy: direct Google Generative Language API (optional)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# Firebase Web App config (Hosting + Firestore + Google Auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
